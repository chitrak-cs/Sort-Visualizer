#include<stdio.h>
#include<stdlib.h>
#include<raylib.h>
#include<stdbool.h>


#define WIDTH 900
#define HEIGHT 600
#define COUNT 5

int numbers[COUNT];

typedef struct {
    bool swapped;
    int i,j;
    bool done;
} sort_status;

void draw_bars(sort_status status){
    for(int i=0;i<COUNT;i++){
        int value = numbers[i];
        float bar_height = (value * HEIGHT * 0.75) / COUNT;
        float bar_width = WIDTH/COUNT - 2;
        float xpos = ((float)i / COUNT) * WIDTH;
        float ypos = HEIGHT * 0.75 - bar_height;

        Color color = WHITE;
        if(status.done){
            color = GREEN;
        }
        else if(status.swapped && (i == status.i || i == status.j)){
            color = RED;
        }
        DrawRectangle(xpos,ypos,bar_width,bar_height,color);
    }
}

void swap(int i, int j){
    int temp = numbers[i];
    numbers[i] = numbers[j];
    numbers[j] = temp;
}

void initialise_numbers(){
    for(int i=0;i<COUNT;i++){
        numbers[i] = i+1;
    }

    // Fisher Yates Shuffle
    for(int i=COUNT-1;i>=0;i--){
        int j = rand() % (i+1);
        // generate a number between 0 and i

        swap(i,j);
    }
}

sort_status sort_step(){

    static sort_status status = (sort_status) {false,0,1,false};
    static bool any_swap_during_sweep = false;
    static int i= 0;

    status.i = i;
    status.j = i+1;

    if(i<COUNT-1){
        int curr_value = numbers[i];
        int next_value = numbers[i+1];
        if(curr_value > next_value){
            swap(i,i+1);
            status.swapped = true;
            any_swap_during_sweep = true;
        }
        else{
            status.swapped = false;
        }
        i++;
    }
    else{
        if(!any_swap_during_sweep){
            status.done = true;
        }
        // end of the array is reached, go back to 0 index and sort again
        i = 0;
        any_swap_during_sweep = false;
    }

    return status;

}

int main(){

    initialise_numbers();

    InitWindow(WIDTH,HEIGHT,"Sorting Visualizer");

    sort_status status;
    SetTargetFPS(COUNT/3);
    while(!WindowShouldClose()){
        if(status.done != true){
            status = sort_step();
        }

        BeginDrawing();
        ClearBackground(BLACK);

        draw_bars(status);
        EndDrawing();
    }

    CloseWindow();
}